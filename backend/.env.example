COPRODUCT_API_TOKEN=dev-token
COPRODUCT_AUTH_MODE=jwt
COPRODUCT_JWT_SECRET=dev-jwt-secret-change-me
COPRODUCT_REFRESH_TOKEN_SECRET=dev-refresh-secret-change-me
COPRODUCT_CSRF_SECRET=dev-csrf-secret-change-me
COPRODUCT_API_KEY_PEPPER=dev-api-key-pepper-change-me
COPRODUCT_ACCESS_TOKEN_TTL_SECONDS=3600
COPRODUCT_REFRESH_TOKEN_TTL_SECONDS=1209600
COPRODUCT_AUTH_COOKIE_SECURE=false
COPRODUCT_AUTH_COOKIE_SAMESITE=lax
COPRODUCT_REFRESH_COOKIE_NAME=refresh_token
COPRODUCT_CSRF_COOKIE_NAME=csrf_token
COPRODUCT_REFRESH_COOKIE_PATH=/api/auth
COPRODUCT_CSRF_COOKIE_PATH=/
COPRODUCT_DEFAULT_ORG_ID=org_default
COPRODUCT_BOOTSTRAP_OWNER_EMAIL=owner@coproduct.local
COPRODUCT_BOOTSTRAP_OWNER_DISPLAY_NAME=Bootstrap Owner
COPRODUCT_BOOTSTRAP_OWNER_API_KEY=cpk_dev_bootstrap_owner_key_change_me
COPRODUCT_DATABASE_URL=postgresql+psycopg://coproduct:coproduct@localhost:5432/coproduct
COPRODUCT_DATABASE_ECHO=false
COPRODUCT_UPLOAD_DIR=./uploaded_files
COPRODUCT_UPLOAD_MAX_SIZE_MB=20
COPRODUCT_CORS_ALLOW_ORIGINS=http://localhost:3000

# Agent model runtime: heuristic | cloud
COPRODUCT_MODEL_MODE=heuristic
COPRODUCT_MODEL_PROVIDER=openai_compatible
COPRODUCT_MODEL_API_KEY=
COPRODUCT_MODEL_BASE_URL=https://api.deepseek.com
COPRODUCT_MODEL_CHAT_MODEL=deepseek-chat
COPRODUCT_MODEL_EMBEDDING_MODEL=
COPRODUCT_MODEL_TIMEOUT_SECONDS=30
COPRODUCT_MODEL_STRUCTURED_RETRIES=1
COPRODUCT_MODEL_TEMPERATURE=0
